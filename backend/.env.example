PORT=8000
NODE_ENV=production

# Local Docker compose overrides DATABASE_URL automatically.
# For Render, set this from Supabase's PostgreSQL connection string.
DATABASE_URL=

# Vercel frontend URL in production, for example:
# FRONTEND_ORIGINS=https://your-app.vercel.app
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Ollama web API
OLLAMA_URL=https://ollama.com/api/generate
OLLAMA_MODEL=gpt-oss:120b
OLLAMA_API_KEY=
